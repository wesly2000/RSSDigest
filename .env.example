OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

MODEL_TEXT_DEFAULT=deepseek/deepseek-chat
MODEL_VIDEO_DEFAULT=google/gemini-2.5-flash-lite
DIGEST_WINDOW_DAYS=7
MAX_ITEMS_PER_FEED=20
REQUEST_TIMEOUT_SECONDS=45
FEED_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
BILIBILI_UID=
BILIBILI_COOKIE=
# Optional per-uid cookie key pattern:
# BILIBILI_COOKIE_438767999=

GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=
DIGEST_EMAIL_TO=
DIGEST_EMAIL_FROM=

DRY_RUN=false
